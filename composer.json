{
    "name": "gpapakitsos/laravel-datatables-api",
    "description": "jQuery DataTables API for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "George Papakitsos",
            "email": "papakitsos_george@yahoo.gr",
            "homepage": "https://papakitsos.gr"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10.0",
        "illuminate/http": "^10.0",
        "illuminate/routing": "^10.0",
        "illuminate/support": "^10.0",
        "nesbot/carbon": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "GPapakitsos\\LaravelDatatables\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GPapakitsos\\LaravelDatatables\\Tests\\": "tests/",
            "Database\\Factories\\": "tests/database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GPapakitsos\\LaravelDatatables\\DatatablesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
